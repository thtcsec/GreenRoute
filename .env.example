# GreenRoute - Environment Variables Example
# Bản đồ OpenStreetMap chạy mặc định không cần API key.
# Cấu hình các biến môi trường dưới đây nếu cần mở rộng:

NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
